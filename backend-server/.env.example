# tokopt backend server config. Copy to .env (gitignored) for local runs, or set
# these as real secrets in whatever platform you deploy this to.

PORT=8788

# Compression (kompress-v2-base, ONNX, runs in this process — no key needed)
KOMPRESS_MODEL=chopratejas/kompress-v2-base
KOMPRESS_ONNX=onnx/kompress-fp32.onnx
KOMPRESS_THRESHOLD=0.5

# Routing proxy — this key is SPENT ON YOUR BEHALF by anyone who reaches this
# endpoint without their own ROUTER_* env vars set. Keep the allowlist tight.
UPSTREAM_ROUTER_BASE_URL=https://api.openai.com/v1
UPSTREAM_ROUTER_API_KEY=sk-...
ROUTER_MODEL_ALLOWLIST=gpt-4.1-nano
RATE_LIMIT_PER_MIN=30

# GET /usage auth. Leave unset to disable /usage entirely (404).
ADMIN_TOKEN=

METRICS_DB=./usage.db
